<idea-plugin>
    <id>org.akasha.intellij</id>
    <name>Akasha</name>
    <vendor email="hello@akasha-lang.org" url="https://github.com/EmmaLeonhart/akasha">Akasha</vendor>

    <description><![CDATA[
        <h2>Akasha Language Support</h2>
        <p>
            Reference IDE support for <b>Akasha</b> — the fuzzy-by-default vector
            programming language whose primitives are hypervectors in embedding
            space.
        </p>
        <p>This is the v0.1 scaffold. It provides:</p>
        <ul>
            <li>File type registration for <code>.ak</code> sources</li>
            <li>Hand-written lexer + syntax highlighter</li>
            <li>Color settings page with every token category exposed</li>
            <li>Bracket matching, line/block comment support</li>
            <li>Keyword / primitive-type / builtin completion</li>
            <li>Live templates ported from the VS Code extension snippets</li>
            <li>External annotator that shells out to <code>akashac --json</code>
                and surfaces diagnostics in the editor and Problems panel</li>
        </ul>
        <p>
            The design target is much bigger than this — see
            <code>planning/akasha-spec/20-ide-architecture.md</code> in the
            Akasha repository for the full IDE vision (embedding-space visualizer,
            fly-brain visualizer, runtime MCP server hosting, agent-first
            authoring, etc.). The scaffold is the foundation those features
            build on.
        </p>
    ]]></description>

    <change-notes><![CDATA[
        <h3>0.1.0 — initial scaffold</h3>
        <ul>
            <li>File type + language registration for <code>.ak</code></li>
            <li>Hand-written lexer covering all four comment forms, interpolated
                and plain strings, keywords, primitive types, builtins, numbers,
                operators, and the illegal <code>|&gt;</code> pipe-forward token</li>
            <li>Syntax highlighter + color settings page</li>
            <li>Brace matcher, commenter, and quote handler config</li>
            <li>Keyword / primitive / builtin completion contributor</li>
            <li>Live templates matching the VS Code extension snippets</li>
            <li>External annotator wiring diagnostics from
                <code>python -m akasha_compiler --json</code></li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Core language + file type registration. -->
        <fileType
            name="Akasha"
            language="Akasha"
            implementationClass="org.akasha.intellij.AkashaFileType"
            fieldName="INSTANCE"
            extensions="ak"/>

        <lang.parserDefinition
            language="Akasha"
            implementationClass="org.akasha.intellij.AkashaParserDefinition"/>

        <!-- Highlighter + color settings. -->
        <lang.syntaxHighlighterFactory
            language="Akasha"
            implementationClass="org.akasha.intellij.AkashaSyntaxHighlighterFactory"/>

        <colorSettingsPage
            implementation="org.akasha.intellij.AkashaColorSettingsPage"/>

        <!-- Editor UX: brace matching, commenting, quoting. -->
        <lang.braceMatcher
            language="Akasha"
            implementationClass="org.akasha.intellij.AkashaBraceMatcher"/>

        <lang.commenter
            language="Akasha"
            implementationClass="org.akasha.intellij.AkashaCommenter"/>

        <lang.quoteHandler
            language="Akasha"
            implementationClass="org.akasha.intellij.AkashaQuoteHandler"/>

        <!-- Completion. -->
        <completion.contributor
            language="Akasha"
            implementationClass="org.akasha.intellij.AkashaCompletionContributor"/>

        <!-- External annotator wired to the akashac JSON diagnostics mode. -->
        <externalAnnotator
            language="Akasha"
            implementationClass="org.akasha.intellij.AkashaExternalAnnotator"/>

        <!-- Default live-template context. The `file` attribute is a
             resources-root-relative path with NO `.xml` extension — the
             platform appends it. -->
        <defaultLiveTemplates file="/liveTemplates/Akasha"/>
        <liveTemplateContext
            contextId="AKASHA"
            implementation="org.akasha.intellij.AkashaLiveTemplateContext"/>

        <!-- Application-level persistent settings for the compiler path. -->
        <applicationService
            serviceImplementation="org.akasha.intellij.AkashaSettings"/>

        <!-- Settings UI under Settings → Tools → Akasha. -->
        <applicationConfigurable
            parentId="tools"
            id="org.akasha.intellij.settings"
            displayName="Akasha"
            instance="org.akasha.intellij.AkashaSettingsConfigurable"/>

        <!-- Visualizer tool windows. Both live on the right side by default,
             each loading a JCEF browser that renders a pure Canvas 2D scene
             from a bundled HTML resource. See planning/akasha-spec/20-ide-architecture.md
             and planning/fly-brain-visualizer.md for the design rationale
             and delivery tiers. -->
        <toolWindow
            id="Akasha Embedding Space"
            anchor="right"
            icon="AllIcons.Toolwindows.ToolWindowStructure"
            factoryClass="org.akasha.intellij.viz.AkashaEmbeddingToolWindowFactory"/>
        <toolWindow
            id="Akasha Fly Brain"
            anchor="right"
            icon="AllIcons.Toolwindows.ToolWindowStructure"
            factoryClass="org.akasha.intellij.viz.AkashaFlyBrainToolWindowFactory"/>
    </extensions>
</idea-plugin>
