
vector v_cat = embed("cat");
vector v_dog = embed("dog");
vector v_bird = embed("bird");

function vector bundle_all() {
    vector acc = embed("zero");
    foreach (vector x in [v_cat, v_dog, v_bird]) {
        acc = bundle(acc, x);
    }
    return acc;
}

function string main() {
    vector result = bundle_all();
    return "ok";
}
