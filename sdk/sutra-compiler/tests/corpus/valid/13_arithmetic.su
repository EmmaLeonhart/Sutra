// Sutra corpus test: arithmetic and numeric literals.
// Covers: integer and float literals, basic math, precedence.

function number Arith() {
    number a = 1;
    number b = 2.0;
    number c = 3.14;
    number d = 0.001;

    number sum = a + b + c;
    number product = a * b * c;
    number mixed = a + b * c - d;
    number div = a / b;
    number mod = a % b;

    return sum + product - mixed + div + mod;
}

function number PrecedenceSanity(number x, number y, number z) {
    // * binds tighter than +
    number p1 = x + y * z;
    // parens override
    number p2 = (x + y) * z;
    // unary minus
    number p3 = -x;
    // unary plus (legal but redundant)
    number p4 = +x;
    // negation inside a nested expression
    number p5 = -x + y * -z;
    return p1 + p2 + p3 + p4 + p5;
}

function bool Compare(number a, number b) {
    bool r1 = a < b;
    bool r2 = a <= b;
    bool r3 = a > b;
    bool r4 = a >= b;
    bool r5 = a == b;
    bool r6 = a != b;
    return r1;
}
