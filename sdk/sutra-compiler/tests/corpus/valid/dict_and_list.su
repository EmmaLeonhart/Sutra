
vector v_cat = embed("cat");
vector v_dog = embed("dog");
vector v_whiskers = embed("whiskers");
vector v_bark = embed("bark");

function vector dict_demo() {
    // Empty dict, add two entries, retrieve one.
    dict<vector, vector> concept_memory;
    concept_memory[v_cat] = v_whiskers;
    concept_memory[v_dog] = v_bark;
    return concept_memory[v_cat];
}

function vector dict_csharp_demo() {
    // C#-style spelling: explicit `new dict()` constructor and
    // `.Add(k, v)` method. Lowers to the same hashmap_new + hashmap_set
    // calls as the bare-declaration + subscript-assign form above.
    dict<vector, vector> concept_memory = new dict();
    concept_memory.Add(v_cat, v_whiskers);
    concept_memory.Add(v_dog, v_bark);
    return concept_memory[v_cat];
}

function int list_demo() {
    // list<T> from a literal — Python list under the hood.
    list<int> items = [10, 20, 30];
    var total : int = 0;
    foreach (int x in [10, 20, 30]) {
        total += x;
    }
    return total;
}

function string main() {
    return "ok";
}
