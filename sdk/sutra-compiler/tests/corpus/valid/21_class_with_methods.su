
class VSA extends vector {
    static intrinsic method vector zero_vector();
    static intrinsic method number similarity(vector a, vector b);
}

// Object loops — loop function declarations inside a class body.
// The codegen emits `_loop_Counter_addOne` and the call site
// `loop Counter.addOne(...)` dispatches to it.
class Counter extends vector {
    static do_while addOne(x < 5, int x) {
        pass x + 1;
    }
}

class Math extends vector {
    static method number twice(number x) {
        return x * 2;
    }

    static method number square(number x) {
        number y = x * x;
        return y;
    }
}

class Greeter extends vector {
    method string Hello() {
        return $"hello from {this.name}";
    }

    method string Goodbye() {
        return $"bye from {this.name}";
    }
}
