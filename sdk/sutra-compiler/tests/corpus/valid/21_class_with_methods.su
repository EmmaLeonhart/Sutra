// Sutra corpus test: classes with method bodies.
//
// Class bodies can contain method declarations as of 2026-05-01
// (extending the empty-body MVP). Static and non-static methods are
// both accepted; static intrinsic methods (signature-only, runtime
// implements them) also parse. Field declarations and operator
// overloads remain deferred. Static methods compile end-to-end with
// `Class.method(...)` dispatch; non-static method codegen is
// deferred (validator accepts them, codegen rejects).

class VSA extends vector {
    static intrinsic method vector zero_vector();
    static intrinsic method scalar similarity(vector a, vector b);
}

class Math extends vector {
    static method scalar twice(scalar x) {
        return x * 2;
    }

    static method scalar square(scalar x) {
        scalar y = x * x;
        return y;
    }
}

class Greeter extends vector {
    method string Hello() {
        return $"hello from {this.name}";
    }

    method string Goodbye() {
        return $"bye from {this.name}";
    }
}
