// Sutra corpus test: character literals.
//
// Per the 2026-04-23 literals design, `'a'` is a single-quoted
// character literal. At compile time it types as an int (chars live
// on the number axis same as ints). At runtime it's a vector with
// synthetic[AXIS_REAL] set to the Unicode code point and
// synthetic[AXIS_CHAR_FLAG] = 1.0. The flag is the only thing that
// distinguishes `'a'` from the plain int `97`.

function int PlainChar() {
    return 'a';
}

function int EscapedNewline() {
    return '\n';
}

function int EscapedQuote() {
    return '\'';
}

function int EscapedBackslash() {
    return '\\';
}

function int Zero() {
    return '0';
}

function int CharArithmetic() {
    // Adding 1 to 'A' should still land on the number axis.
    var base : int = 'A';
    return base + 1;
}
