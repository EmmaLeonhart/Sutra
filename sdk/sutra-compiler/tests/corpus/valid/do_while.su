// do-while desugars to a single body execution followed by a while
// loop with the same body + condition. User direction 2026-04-22.
//
// The while-half compiles to eigenrotation via the existing
// WhileStmt lowering, so this test just exercises the
// decompose-and-translate path.

vector v_cat = basis_vector("cat");
vector v_dog = basis_vector("dog");

function vector wander_at_least_once(vector start) {
    vector state = start;
    do {
        state = state;
    } while (similarity(state, v_dog) < 0.9);
    return state;
}

function string main() {
    vector result = wander_at_least_once(v_cat);
    return "ok";
}
