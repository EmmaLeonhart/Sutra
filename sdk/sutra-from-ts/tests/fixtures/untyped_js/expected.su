// Expected lowering of untyped_js/input.js.
//
// Notes:
//   - The function `double_or_concat` has no type annotations. Its
//     parameter `x` becomes `JavaScriptObject x` — the concrete
//     fallback class for unresolved JS values. Its return type also
//     becomes `JavaScriptObject` (the `+` operator on
//     JavaScriptObject preserves the fallback type).
//   - The `+` operator on JavaScriptObject lowers to a static method
//     `JavaScriptObject.add(a, b)` on the wrapping class. That static
//     method implements JS's `+` semantics (string-concat OR numeric-
//     add depending on the runtime types of its operands).
//   - The integer literal `7` gets implicitly wrapped into a
//     JavaScriptObject when passed as an argument to a function
//     expecting JavaScriptObject. The wrap is whatever the
//     JavaScriptObject runtime defines as "from a numeric literal."
//
// What this fixture does today:
//   - Does NOT compile yet. `JavaScriptObject` is not a Sutra class —
//     the transpiler's runtime stdlib will need to define it. Until
//     then, this expected.su is illustrative only.
//   - The String-handling caveat from DESIGN.md applies too: if the
//     JS code uses string operations, those need the (also-deferred)
//     Sutra String class.

function JavaScriptObject double_or_concat(JavaScriptObject x) {
    return JavaScriptObject.add(x, x);
}

function JavaScriptObject main() {
    return double_or_concat(JavaScriptObject.from(7));
}
