// Expected lowering of untyped_js/input.js.
//
// Notes:
//   - The function `double_or_concat` has no type annotations. Its
//     parameter `x` becomes `JavaScriptObject x` — the concrete
//     fallback class for unresolved JS values. Its return type also
//     becomes `JavaScriptObject` (the `+` operator on
//     JavaScriptObject preserves the fallback type).
//   - `+` between JavaScriptObject operands lowers to a static
//     method `JavaScriptObject.js_add(a, b)`. The runtime
//     implementation does element-wise vector add — numeric `+` for
//     number-axis operands; richer JS-coercive semantics (string
//     concat detection) is deferred.
//   - A primitive literal passed to a JavaScriptObject parameter is
//     wrapped via `JavaScriptObject.wrap(...)`. Named `wrap` rather
//     than `from` because `from` is a Python keyword — the static-
//     intrinsic dispatch routes `JavaScriptObject.from(7)` to
//     `_VSA.from(7)` which is a Python syntax error.

function JavaScriptObject double_or_concat(JavaScriptObject x) {
    return JavaScriptObject.js_add(x, x);
}

function JavaScriptObject main() {
    return double_or_concat(JavaScriptObject.wrap(7));
}
