// Expected lowering of for_loop_sum/input.ts.
//
// Notes:
//   - `for (init; cond; incr) body` desugars to (init; while-equiv).
//     The init runs as a regular statement before the loop. The
//     condition and the body+increment hoist into a declared
//     `while_loop` (same machinery as plain while). The increment
//     is folded onto the body's tail so it runs at iteration end.
//   - `let i = 0` in the initializer becomes `slot int i = 0`
//     before the loop call.

while_loop _loop_0(i < n, int i = 0, int n = 0, int sum = 0) {
    sum = sum + i;
    i = i + 1;
}

function int sum_to(int n) {
    slot int sum = 0;
    slot int i = 0;
    slot int _i_l0 = i;
    slot int _n_l0 = n;
    slot int _sum_l0 = sum;
    loop _loop_0(i < n, _i_l0, _n_l0, _sum_l0);
    i = _i_l0;
    n = _n_l0;
    sum = _sum_l0;
    return sum;
}

function int main() {
    return sum_to(10);
}
