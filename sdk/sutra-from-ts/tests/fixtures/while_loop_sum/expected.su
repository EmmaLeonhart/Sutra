// Expected lowering of while_loop_sum/input.ts.
//
// Notes:
//   - Sutra's codegen rejects inline `while (cond) { body }` in
//     favor of the declared-loop form. The transpiler hoists the
//     while loop into a top-level `while_loop _loop_N(...)` decl
//     plus a `loop _loop_N(...)` call at the original site.
//   - All locals referenced in the cond or body become state
//     params on the loop function. Slot copies are declared at the
//     call site (Sutra requires loop args to be slot vars), and
//     mutated locals are written back from the slot copies after
//     the loop returns.
//   - State params show up alphabetically because the variable
//     analysis returns a sorted set.

while_loop _loop_0(i < n, int i = 0, int n = 0, int sum = 0) {
    sum = sum + i;
    i = i + 1;
}

function int sum_up_to(int n) {
    slot int sum = 0;
    slot int i = 0;
    slot int _i_l0 = i;
    slot int _n_l0 = n;
    slot int _sum_l0 = sum;
    loop _loop_0(i < n, _i_l0, _n_l0, _sum_l0);
    i = _i_l0;
    n = _n_l0;
    sum = _sum_l0;
    return sum;
}

function int main() {
    return sum_up_to(10);
}
