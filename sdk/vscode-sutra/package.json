{
  "name": "vscode-sutra",
  "displayName": "Sutra Language",
  "description": "Syntax highlighting, autocomplete, and error reporting for the Sutra programming language.",
  "version": "0.1.0",
  "publisher": "sutra-lang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "keywords": [
    "sutra",
    "vector",
    "fuzzy",
    "embedding",
    "vsa",
    "hyperdimensional"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:sutra"
  ],
  "contributes": {
    "languages": [
      {
        "id": "sutra",
        "aliases": ["Sutra", "sutra"],
        "extensions": [".ak"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/sutra-icon.svg",
          "dark": "./images/sutra-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "sutra",
        "scopeName": "source.sutra",
        "path": "./syntaxes/sutra.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "sutra",
        "path": "./snippets/sutra.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Sutra",
      "properties": {
        "sutra.compilerPath": {
          "type": "string",
          "default": "python",
          "description": "Command or absolute path to the Python interpreter used to run the sutrac compiler."
        },
        "sutra.compilerArgs": {
          "type": "array",
          "default": ["-m", "sutra_compiler"],
          "items": { "type": "string" },
          "description": "Arguments passed to sutra.compilerPath before the file path. Defaults to running `python -m sutra_compiler`."
        },
        "sutra.validateOn": {
          "type": "string",
          "enum": ["save", "change", "never"],
          "default": "save",
          "description": "When to re-run the validator: on every edit, on save only, or never (manual only)."
        },
        "sutra.showDiagnosticCodes": {
          "type": "boolean",
          "default": true,
          "description": "Show the SUT#### diagnostic code in the Problems panel."
        }
      }
    },
    "commands": [
      {
        "command": "sutra.validateFile",
        "title": "Sutra: Validate current file"
      },
      {
        "command": "sutra.validateWorkspace",
        "title": "Sutra: Validate all .ak files in workspace"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  }
}
