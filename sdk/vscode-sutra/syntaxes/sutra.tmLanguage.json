{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sutra",
  "scopeName": "source.sutra",
  "fileTypes": ["su"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#declarations" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.sutra",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.sutra",
          "match": "//.*$"
        },
        {
          "name": "comment.line.number-sign.sutra",
          "match": "#.*$"
        },
        {
          "name": "comment.block.sutra",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.sutra" }
          }
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.interpolated.sutra",
          "begin": "\\$\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.sutra" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.sutra" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.sutra",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.sutra",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.section.embedded.begin.sutra" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.embedded.end.sutra" }
              },
              "patterns": [
                { "include": "#keywords" },
                { "include": "#types" },
                { "include": "#builtins" },
                { "include": "#numbers" },
                { "include": "#operators" },
                { "include": "#strings" },
                { "include": "#identifiers" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.double.sutra",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sutra",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sutra",
          "match": "\\b(if|else|while|for|foreach|in|do|loop|as|return|try|catch|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.sutra",
          "match": "\\b(function|method|operator|var|const|static|public|private|implicit|class|extends|slot)\\b"
        },
        {
          "name": "variable.language.this.sutra",
          "match": "\\bthis\\b"
        },
        {
          "name": "storage.modifier.sutra",
          "match": "\\b(new)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.sutra",
          "match": "\\b(scalar|vector|matrix|tuple|string|bool|fuzzy|void|permutation|map|char|int|float|complex|trit)\\b"
        },
        {
          "name": "entity.name.type.sutra",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },

    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.sutra",
          "match": "\\b(embed|defuzzy|unsafeCast|unsafeOverride|snap|similarity|Bundle|Bind|Cosine|Normalize|Blend)\\b"
        },
        {
          "name": "keyword.other.function-prefix.sutra",
          "match": "\\bfunction\\s*\\.",
          "captures": {
            "0": { "name": "keyword.other.function-prefix.sutra" }
          }
        }
      ]
    },

    "declarations": {
      "patterns": [
        {
          "comment": "function declaration: function <mods>? <type> <name>(",
          "match": "\\b(function)\\s+(?:public\\s+|private\\s+|static\\s+)*([A-Za-z_][A-Za-z0-9_]*)(?:\\s*<[^>]+>)?\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=[<(])",
          "captures": {
            "1": { "name": "keyword.declaration.sutra" },
            "2": { "name": "support.type.sutra" },
            "3": { "name": "entity.name.function.sutra" }
          }
        },
        {
          "comment": "method declaration: method <type> <name>(",
          "match": "\\b(method)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s*<[^>]+>)?\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=[<(])",
          "captures": {
            "1": { "name": "keyword.declaration.sutra" },
            "2": { "name": "support.type.sutra" },
            "3": { "name": "entity.name.function.sutra" }
          }
        },
        {
          "comment": "function call",
          "match": "([A-Za-z_][A-Za-z0-9_]*)\\s*(?=<[^>]+>\\s*\\(|\\()",
          "captures": {
            "1": { "name": "entity.name.function.sutra" }
          }
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.sutra",
          "match": "\\b(true|false)\\b"
        },
        {
          "comment": "Three-valued truth neutral point: `unknown` (long form) and `unk` (short alias).",
          "name": "constant.language.unknown.sutra",
          "match": "\\b(unknown|unk)\\b"
        },
        {
          "comment": "Explicit deferred-initializer marker: `int i = wait;`. Only legal as a var-decl initializer; the validator enforces that an assignment follows before the function returns.",
          "name": "constant.language.wait.sutra",
          "match": "\\bwait\\b"
        },
        {
          "comment": "Char literal: single-quoted character, with backslash escapes (e.g. '\\n', '\\'').",
          "name": "string.quoted.single.sutra",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.sutra",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "comment": "Imaginary suffix: `5i`, `3.14i`.",
          "name": "constant.numeric.imaginary.sutra",
          "match": "\\b[0-9]+(?:\\.[0-9]+)?i\\b"
        },
        {
          "name": "constant.numeric.decimal.sutra",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.sutra",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.sutra",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.sutra",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.sutra",
          "match": "=|\\+=|-=|\\*=|/="
        },
        {
          "name": "keyword.operator.arithmetic.sutra",
          "match": "\\+\\+|--|\\+|-|\\*|/|%"
        },
        {
          "name": "invalid.illegal.pipe-forward.sutra",
          "match": "\\|>"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.sutra",
          "match": ","
        },
        {
          "name": "punctuation.terminator.statement.sutra",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.sutra",
          "match": "\\."
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.sutra",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
