<idea-plugin>
    <id>org.sutra.intellij</id>
    <name>Sutra</name>
    <vendor email="hello@sutra-lang.org" url="https://github.com/EmmaLeonhart/sutra">Sutra</vendor>

    <description><![CDATA[
        <h2>Sutra Language Support</h2>
        <p>
            Reference IDE support for <b>Sutra</b> — the fuzzy-by-default vector
            programming language whose primitives are hypervectors in embedding
            space.
        </p>
        <p>This is the v0.1 scaffold. It provides:</p>
        <ul>
            <li>File type registration for <code>.su</code> sources</li>
            <li>Hand-written lexer + syntax highlighter</li>
            <li>Color settings page with every token category exposed</li>
            <li>Bracket matching, line/block comment support</li>
            <li>Keyword / primitive-type / builtin completion</li>
            <li>Live templates ported from the VS Code extension snippets</li>
            <li>External annotator that shells out to <code>sutrac --json</code>
                and surfaces diagnostics in the editor and Problems panel</li>
        </ul>
        <p>
            The design target is much bigger than this — see
            <code>planning/sutra-spec/20-ide-architecture.md</code> in the
            Sutra repository for the full IDE vision (embedding-space visualizer,
            fly-brain visualizer, runtime MCP server hosting, agent-first
            authoring, etc.). The scaffold is the foundation those features
            build on.
        </p>
    ]]></description>

    <change-notes><![CDATA[
        <h3>0.1.0 — initial scaffold</h3>
        <ul>
            <li>File type + language registration for <code>.su</code></li>
            <li>Hand-written lexer covering all four comment forms, interpolated
                and plain strings, keywords, primitive types, builtins, numbers,
                operators, and the illegal <code>|&gt;</code> pipe-forward token</li>
            <li>Syntax highlighter + color settings page</li>
            <li>Brace matcher, commenter, and quote handler config</li>
            <li>Keyword / primitive / builtin completion contributor</li>
            <li>Live templates matching the VS Code extension snippets</li>
            <li>External annotator wiring diagnostics from
                <code>python -m sutra_compiler --json</code></li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Core language + file type registration. -->
        <fileType
            name="Sutra"
            language="Sutra"
            implementationClass="org.sutra.intellij.SutraFileType"
            fieldName="INSTANCE"
            extensions="su"/>

        <lang.parserDefinition
            language="Sutra"
            implementationClass="org.sutra.intellij.SutraParserDefinition"/>

        <!-- Highlighter + color settings. -->
        <lang.syntaxHighlighterFactory
            language="Sutra"
            implementationClass="org.sutra.intellij.SutraSyntaxHighlighterFactory"/>

        <colorSettingsPage
            implementation="org.sutra.intellij.SutraColorSettingsPage"/>

        <!-- Editor UX: brace matching, commenting, quoting. -->
        <lang.braceMatcher
            language="Sutra"
            implementationClass="org.sutra.intellij.SutraBraceMatcher"/>

        <lang.commenter
            language="Sutra"
            implementationClass="org.sutra.intellij.SutraCommenter"/>

        <lang.quoteHandler
            language="Sutra"
            implementationClass="org.sutra.intellij.SutraQuoteHandler"/>

        <!-- Completion. -->
        <completion.contributor
            language="Sutra"
            implementationClass="org.sutra.intellij.SutraCompletionContributor"/>

        <!-- External annotator wired to the sutrac JSON diagnostics mode. -->
        <externalAnnotator
            language="Sutra"
            implementationClass="org.sutra.intellij.SutraExternalAnnotator"/>

        <!-- Default live-template context. The `file` attribute is a
             resources-root-relative path with NO `.xml` extension — the
             platform appends it. -->
        <defaultLiveTemplates file="/liveTemplates/Sutra"/>
        <liveTemplateContext
            contextId="SUTRA"
            implementation="org.sutra.intellij.SutraLiveTemplateContext"/>

        <!-- Application-level persistent settings for the compiler path. -->
        <applicationService
            serviceImplementation="org.sutra.intellij.SutraSettings"/>

        <!-- Settings UI under Settings → Tools → Sutra. -->
        <applicationConfigurable
            parentId="tools"
            id="org.sutra.intellij.settings"
            displayName="Sutra"
            instance="org.sutra.intellij.SutraSettingsConfigurable"/>

        <!-- Visualizer tool windows. Both live on the right side by default,
             each loading a JCEF browser that renders a pure Canvas 2D scene
             from a bundled HTML resource. See planning/sutra-spec/20-ide-architecture.md
             and planning/fly-brain-visualizer.md for the design rationale
             and delivery tiers. -->
        <toolWindow
            id="Sutra Embedding Space"
            anchor="right"
            icon="AllIcons.Toolwindows.ToolWindowStructure"
            factoryClass="org.sutra.intellij.viz.SutraEmbeddingToolWindowFactory"/>
        <toolWindow
            id="Sutra Fly Brain"
            anchor="right"
            icon="AllIcons.Toolwindows.ToolWindowStructure"
            factoryClass="org.sutra.intellij.viz.SutraFlyBrainToolWindowFactory"/>

        <!-- Sutra Workspace tool window. Lives on the left by default
             because it is a project-structure browser, next to the
             built-in Project view. Scans the project root for an
             atman.toml file and renders the workspace structure as a
             tree of projects and source files, with double-click to
             open. No custom file type registration is needed — the
             bundled IntelliJ TOML plugin already handles atman.toml
             as a .toml file, and the workspace tool window
             disambiguates by filename at scan time. See
             planning/sutra-spec/22-workspaces.md for the format spec. -->
        <toolWindow
            id="Sutra Workspace"
            anchor="left"
            secondary="true"
            icon="AllIcons.Toolwindows.ToolWindowModuleDependencies"
            factoryClass="org.sutra.intellij.workspace.SutraWorkspaceToolWindowFactory"/>

        <!-- Run support: `function string main()` is the entry point. The
             gutter icon on `main` and right-click "Run" both build a
             SutraRunConfiguration that shells the reference compiler with
             the run flag. See SutraRunConfiguration.kt. -->
        <configurationType
            implementation="org.sutra.intellij.run.SutraRunConfigurationType"/>
        <runConfigurationProducer
            implementation="org.sutra.intellij.run.SutraRunConfigurationProducer"/>
        <runLineMarkerContributor
            language="Sutra"
            implementationClass="org.sutra.intellij.run.SutraRunLineMarkerContributor"/>
    </extensions>
</idea-plugin>
