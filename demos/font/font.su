}

function vector glyph_pixel(number x, number y, number char_code) {
    number pos = y * 5.0 + x;

    // Per-letter bit at this position. Each `bit_<C>(pos)` is a 25-way
    // defuzzified select over the 25 grid positions of letter <C>.
    vector b_A = bit_A(pos);
    vector b_B = bit_B(pos);
    vector b_C = bit_C(pos);
    vector b_D = bit_D(pos);
    vector b_E = bit_E(pos);
    vector b_F = bit_F(pos);
    vector b_G = bit_G(pos);
    vector b_H = bit_H(pos);
    vector b_I = bit_I(pos);
    vector b_J = bit_J(pos);
    vector b_K = bit_K(pos);
    vector b_L = bit_L(pos);
    vector b_M = bit_M(pos);
    vector b_N = bit_N(pos);
    vector b_O = bit_O(pos);
    vector b_P = bit_P(pos);
    vector b_Q = bit_Q(pos);
    vector b_R = bit_R(pos);
    vector b_S = bit_S(pos);
    vector b_T = bit_T(pos);
    vector b_U = bit_U(pos);
    vector b_V = bit_V(pos);
    vector b_W = bit_W(pos);
    vector b_X = bit_X(pos);
    vector b_Y = bit_Y(pos);
    vector b_Z = bit_Z(pos);
    vector b_d0 = bit_0(pos);
    vector b_d1 = bit_1(pos);
    vector b_d2 = bit_2(pos);
    vector b_d3 = bit_3(pos);
    vector b_d4 = bit_4(pos);
    vector b_d5 = bit_5(pos);
    vector b_d6 = bit_6(pos);
    vector b_d7 = bit_7(pos);
    vector b_d8 = bit_8(pos);
    vector b_d9 = bit_9(pos);

    // Score char_code against each letter's codepoint. The softmax-
    // saturation constant (1000) clears float64 underflow (~745), so
    // exp(-1000) is exactly 0 and select is a true one-hot.
    number s_A = 0.0 - 1000.0 * (char_code - 65.0) * (char_code - 65.0);
    number s_B = 0.0 - 1000.0 * (char_code - 66.0) * (char_code - 66.0);
    number s_C = 0.0 - 1000.0 * (char_code - 67.0) * (char_code - 67.0);
    number s_D = 0.0 - 1000.0 * (char_code - 68.0) * (char_code - 68.0);
    number s_E = 0.0 - 1000.0 * (char_code - 69.0) * (char_code - 69.0);
    number s_F = 0.0 - 1000.0 * (char_code - 70.0) * (char_code - 70.0);
