/*
    Geometric loop demo: counting on the fly brain.

    Places prototype vectors at rotation steps 3 and 6,
    then uses geometric_loop to count to each target.
    The loop rotates the state vector through the mushroom
    body circuit at each iteration, terminating when the
    KC pattern matches the target prototype.
*/

// Set up the starting state
vector start = basis_vector("origin")

// Build a rotation matrix (pi/4 per step, across 20 planes)
vector R = make_rotation(0.785, 20)

// Create target prototypes by applying R^3 and R^6 to start
// (In practice these would be pre-computed target states)
vector target_three = snap(bind(start, basis_vector("step_three")))
vector target_six = snap(bind(start, basis_vector("step_six")))
