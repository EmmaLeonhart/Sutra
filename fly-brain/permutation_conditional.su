// Permutation-based conditionals on the Drosophila mushroom body
// Substrate: 50 PNs → 2000 KCs → APL → 20 MBONs (same circuit as
// four_state_conditional.ak — this file shows the *next* compilation
// strategy for the same if-tree).
//
// This file demonstrates how Sutra compiles an if/else tree into pure
// vector operations that execute on a biological connectome, with
// *negation* compiled to a permutation key rather than a Python `not`.
//
// Compilation contract for this file:
//   if/else tree    →  prototype table in the fly brain's output space
//                      (4 snap() calls, one per case, at compile time)
//   condition lookup →  snap(query) + cosine argmax against prototypes
//   `!` negation    →  bind with a fixed permutation key
//   Program variants →  different permutation key compositions on the
//                       SAME prototype table
//
// Runtime invariant: every snap() in this file uses the same MB
// connectivity matrix (fixed seed). Compile-time prototypes and
// decision-time queries decode through the same PN->KC projection,
// so "query matches prototype" is a well-defined comparison.

// --- Primitives ---

// Two state axes. Each axis has exactly two states, and the two states
// of a given axis are related by a permutation key. The compiler is
// responsible for constructing smell_absent as NOT_SMELL * smell_present
// so that `!smell` at the source level is a linear transform on the
// query vector.
vector smell_present = basis_vector("smell");
vector hunger_hungry = basis_vector("hunger");

permutation NOT_SMELL  = permutation_key("NOT_SMELL");
permutation NOT_HUNGER = permutation_key("NOT_HUNGER");

vector smell_absent = permute(NOT_SMELL,  smell_present);
vector hunger_fed   = permute(NOT_HUNGER, hunger_hungry);

// --- Compiled prototype table (Program A, natural mapping) ---
//
// Source-level:
//   if  (smell && hungry)  return approach;
//   if  (smell && !hungry) return ignore;
//   if  (!smell && hungry) return search;
//   if  (!smell && !hungry) return idle;
//
// The compiler lowers this to four brain-view vectors, one per case.
// Each one is produced by binding the smell and hunger states for that
// case and running the result through the mushroom body once. This is
// the compiled artifact — four KC-space patterns that the runtime will
// argmax over. In a real fly, the equivalent artifact is four sets of
// KC->MBON synaptic weights trained on the four contexts.
vector proto_PH = snap(bind(smell_present, hunger_hungry));  // approach
vector proto_PF = snap(bind(smell_present, hunger_fed));     // ignore
vector proto_AH = snap(bind(smell_absent,  hunger_hungry));  // search
vector proto_AF = snap(bind(smell_absent,  hunger_fed));     // idle

// The behavior-name side of the lookup. This is "which MBON fires when
// each KC pattern wins" — wiring, not control flow.
map<vector, string> BEHAVIOR_OF = {
    proto_PH: "approach",
    proto_PF: "ignore",
    proto_AH: "search",
    proto_AF: "idle"
};

// --- Decision ---
//
// Everything below is the runtime decision path. Note that there is
// no `if` in it. The program variants (B/C/D) differ only in which
// permutation keys are applied to the query — they do not have their
// own copy of the if-tree.

function string decide(vector smell, vector hunger,
                       permutation px, permutation py) {
    // 1. Form the conjunctive query.
    vector query = bind(smell, hunger);

    // 2. Apply negations as permutation keys. `px` and `py` are either
    //    identity or the NOT_SMELL / NOT_HUNGER keys depending on which
    //    program is running. The compiler picks them at compile time.
    query = permute(px, query);
    query = permute(py, query);

    // 3. Run the fly brain. The mushroom body's sparse random projection
    //    + APL winner-take-all inhibition produces a brain-view version
    //    of the query. Same connectivity as the compiled prototypes, so
    //    the comparison below is in a consistent reconstruction frame.
    vector brain_query = snap(query);

    // 4. Cosine argmax over the four prototypes. This is the biological
    //    analogue of four MBONs competing for a winner.
    vector winner = argmax_cosine(brain_query, [proto_PH, proto_PF, proto_AH, proto_AF]);

    // 5. Look up the behavior associated with the winning prototype.
    //    No if/elif chain — this is a map lookup, which corresponds to
    //    "which MBON fires → which motor program runs" in the fly.
    return BEHAVIOR_OF[winner];
}

// --- Program variants ---
//
// Each program is literally one pair of permutation keys. Nothing else
// about the program differs. Program A uses identity keys (no inversion),
// Program B inverts the smell axis, Program C inverts hunger, Program D
// inverts both. The if-tree that used to vary between these programs
// is now a single compiled prototype table — the variation lives in
// the query.

permutation I = identity_permutation();

function string program_A(vector smell, vector hunger) {
    return decide(smell, hunger, I, I);
}

function string program_B(vector smell, vector hunger) {
    // `!smell` in the original source is now `permute(NOT_SMELL, .)`
    // applied to the query. Same prototypes, different permutation.
    return decide(smell, hunger, NOT_SMELL, I);
}

function string program_C(vector smell, vector hunger) {
    // `!hungry` in the original source.
    return decide(smell, hunger, I, NOT_HUNGER);
}

function string program_D(vector smell, vector hunger) {
    // `!smell` AND `!hungry`.
    return decide(smell, hunger, NOT_SMELL, NOT_HUNGER);
}
