# Tell GitHub Linguist to recognize .su files as Sutra
*.su linguist-language=Sutra
*.su linguist-detectable=true

# Linguist treats `examples/` as a documentation path and skips the
# whole directory by default — so the .su corpus living there (which
# is also the regression-test corpus, run by examples/_smoke_test.py)
# never reaches the repo's language stats. Force the directory to be
# counted. This is the surgical fix for "Linguist ignores examples/":
# no rename, no refactor of the ~30 files that reference examples/,
# and the frozen paper/neurips/ references stay intact.
examples/** linguist-detectable=true
