/*
    Sutra Example: Types, Casts, and the Substrate

    At runtime, everything is vectors. Classes are compile-time.
    The five primitives: scalar, vector, matrix, tuple, string.
    Classes exist for the compiler's acceptance checking only.

    Key distinction: casts relabel, embed() computes.
    (Cat) animal  → relabel (Cat is already a vector underneath)
    embed("cat")  → real computation (runs through embedding model)
*/

// ── Primitive types ─────────────────────────────────────────

scalar distance = 0.85;
vector cat = embed("cat");
vector dog = embed("dog");
string label = "result";
// matrix and tuple also exist as primitives

// ── Classes are compile-time ────────────────────────────────

// You can define a class. It organizes methods and constrains
// what the compiler accepts. But at runtime it's just a vector.

// Animal is a class. It has methods (see 01-objects-and-methods.ak).
// But Animal values are vectors in embedding space.

Animal myAnimal = (Animal) cat;  // safe cast: vector → Animal


// ── Three ways to get past type checking ────────────────────

function vector GetFur(Cat c) {
    return c.fur;
}

// 1. Safe cast: checks at compile time
Cat checkedCat = (Cat) myAnimal;
GetFur(checkedCat);

// 2. Unsafe cast: forces the type, no checking
Cat forcedCat = unsafeCast<Cat>(myAnimal);
GetFur(forcedCat);

// 3. Unsafe override: doesn't change the value at all,
//    just tells the function to accept it anyway
GetFur(unsafeOverride(myAnimal));


// ── Casting to primitives ───────────────────────────────────

// You can always cast down to the primitive layer
vector v = (vector) checkedCat;
scalar s = (scalar) distance;
string name = (string) checkedCat;  // for output


// ── fuzzy and bool ──────────────────────────────────────────

// fuzzy and bool are distinct types, both vectors underneath
fuzzy similarity = unsafeCast<fuzzy>(Cosine(cat, dog));
bool isSimilar = defuzzy(similarity);

// Casting fuzzy → bool performs defuzzy
bool alsoWorks = (bool) similarity;

// if() requires bool or fuzzy
if (isSimilar) {
    // this works: isSimilar is bool
}

if (similarity) {
    // this also works: similarity is fuzzy
}

// if (cat) { }  ← COMPILATION ERROR
// cat is not bool or fuzzy. You must explicitly convert:
if (unsafeCast<fuzzy>(cat)) {
    // now it works: you opted into geometric truthiness
}


// ── Generics (compile-time only) ────────────────────────────

function T Identity<T>(T value) {
    return value;
}

// At runtime, T is always a vector. The generic only matters
// for the compiler's acceptance checking.
Cat sameCat = Identity<Cat>(checkedCat);
