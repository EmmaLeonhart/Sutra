// Role-filler record under rotation binding — the simplest demo that
// exercises the new bind/unbind machinery end-to-end on the frozen
// LLM embedding substrate.
//
// Rotation binding (role-first convention):
//   bind(role, filler) = Q_role @ filler     (Q_role is a Haar-random
//                                              rotation seeded by the
//                                              role vector's hash)
//   unbind(role, record) = Q_role^T @ record
//
// The record is a bundle of three rotation-bindings. Each role's
// rotation is distinct (seeded by a different role vector), so the
// three bundled contributions decorrelate on retrieval. Retrieval
// via the correct role exactly recovers the filler; retrieval via
// the wrong role gives noise that's near-orthogonal to every filler
// candidate.
//
// Substrate: nomic-embed-text (768-dim) via Ollama, mean-centered.
// Backend: codegen_numpy with rotation binding as of 2026-04-22.

// --- Roles (keys for the three fields) ---
vector r_person = basis_vector("role_person");
vector r_topic  = basis_vector("role_topic");
vector r_mood   = basis_vector("role_mood");

// --- Filler codebook ---
vector f_ada    = basis_vector("filler_ada");
vector f_turing = basis_vector("filler_turing");
vector f_math   = basis_vector("filler_math");
vector f_music  = basis_vector("filler_music");
vector f_happy  = basis_vector("filler_happy");
vector f_tired  = basis_vector("filler_tired");

map<vector, string> FILLER_NAME = {
    f_ada:    "ada",
    f_turing: "turing",
    f_math:   "math",
    f_music:  "music",
    f_happy:  "happy",
    f_tired:  "tired"
};

// --- Encode a record: three rotation-bindings bundled together ---
function vector make_record(vector person, vector topic, vector mood) {
    return bundle(
        bind(r_person, person),
        bind(r_topic,  topic),
        bind(r_mood,   mood)
    );
}

// --- Decode one field: unbind by role, argmax against the codebook ---
function string decode_field(vector record, vector role) {
    vector recovered = unbind(role, record);
    vector winner = argmax_cosine(
        recovered,
        [f_ada, f_turing, f_math, f_music, f_happy, f_tired]
    );
    return FILLER_NAME[winner];
}

function string main() {
    vector rec = make_record(f_ada, f_math, f_happy);
    return decode_field(rec, r_topic);
}
