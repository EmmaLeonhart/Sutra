
vector paris  = embed("paris");
vector france = embed("france");

vector tokyo  = embed("tokyo");
vector japan  = embed("japan");

vector london = embed("london");
vector uk     = embed("uk");

vector rome   = embed("rome");
vector italy  = embed("italy");

vector cairo  = embed("cairo");
vector egypt  = embed("egypt");

map<vector, string> COUNTRY_NAME = {
    france: "france",
    japan:  "japan",
    uk:     "uk",
    italy:  "italy",
    egypt:  "egypt"
};

vector memory = bundle(
    bind(paris,  france),
    bind(tokyo,  japan),
    bind(london, uk),
    bind(rome,   italy),
    bind(cairo,  egypt)
);

function string country_of(vector city) {
    vector recovered = unbind(city, memory);
    vector winner = argmax_cosine(recovered, [france, japan, uk, italy, egypt]);
    return COUNTRY_NAME[winner];
}

function string main() {
    return country_of(paris);
}
