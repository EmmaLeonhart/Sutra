// Concept-search loop: given a starting vector, eigenrotate until the
// trajectory lands in a designated target's basin, then snap to the
// codebook.
//
// This exercises `loop (cond)` as a data-dependent loop — the number
// of iterations needed to reach the target depends on where the
// starting vector sits relative to the target basin. Different
// starts take different counts to converge; the program shape
// (not the input) determines the terminal commit.
//
// Companion to loop_rotation.su, but using a richer codebook (10
// concepts) and a more specific target (animal → mammal family).
// The loop is still the Haar-random eigenrotation the numpy codegen
// emits for `loop (similarity(state, target) < T)`, but the target
// and threshold here are chosen to demonstrate meaningful iteration
// counts on real Ollama embeddings.

// --- 10-concept codebook ---
vector v_cat     = basis_vector("cat");
vector v_dog     = basis_vector("dog");
vector v_horse   = basis_vector("horse");
vector v_cow     = basis_vector("cow");
vector v_sheep   = basis_vector("sheep");
vector v_fish    = basis_vector("fish");
vector v_bird    = basis_vector("bird");
vector v_snake   = basis_vector("snake");
vector v_spider  = basis_vector("spider");
vector v_insect  = basis_vector("insect");

map<vector, string> CONCEPT_NAME = {
    v_cat:    "cat",
    v_dog:    "dog",
    v_horse:  "horse",
    v_cow:    "cow",
    v_sheep:  "sheep",
    v_fish:   "fish",
    v_bird:   "bird",
    v_snake:  "snake",
    v_spider: "spider",
    v_insect: "insect"
};

// Target basin: "mammal." The loop rotates until the state is
// sufficiently close to v_mammal in cosine terms. Different starting
// vectors are different distances from the mammal basin, so the loop
// takes different iteration counts before it snaps.
vector v_mammal = basis_vector("mammal");

// Wander with eigenrotation until cosine(state, v_mammal) >= 0.9,
// then snap to nearest in the 10-concept codebook. Threshold 0.9 is
// high enough that the starting vectors (which have cosine 0.49-0.78
// to v_mammal on nomic) have to iterate; the Haar-random rotation's
// quasi-periodic trajectory eventually brings the state close to
// v_mammal within the max_iters budget. Different starts take
// different iteration counts — that's the data-dependent termination
// `loop (condition)` is for.
function string wander_to_mammal(vector start) {
    vector state = start;
    loop (similarity(state, v_mammal) < 0.9) {
        state = state;
    }
    vector winner = argmax_cosine(state,
        [v_cat, v_dog, v_horse, v_cow, v_sheep,
         v_fish, v_bird, v_snake, v_spider, v_insect]);
    return CONCEPT_NAME[winner];
}

// Five starting vectors, each a different distance from the
// mammal basin. The return values (which codebook entry each
// trajectory lands on) depend on the substrate's geometry + the
// Haar rotation's fixed seed — expected winners are snap-to-
// codebook results, not a priori "this is the closest mammal"
// claims.
function string from_dog() {
    return wander_to_mammal(v_dog);
}

function string from_spider() {
    return wander_to_mammal(v_spider);
}

function string from_insect() {
    return wander_to_mammal(v_insect);
}

function string from_bird() {
    return wander_to_mammal(v_bird);
}

function string from_snake() {
    return wander_to_mammal(v_snake);
}

function string main() {
    return from_dog();
}
