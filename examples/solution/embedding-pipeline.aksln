# embedding-pipeline.aksln — example Akasha solution file
#
# Two-project solution demonstrating the v1 solution system. `corpus`
# declares a static collection of reference vectors; `similarity`
# depends on `corpus` and exposes cosine-similarity queries against it.
# Both projects target the silicon substrate (the default), i.e. an
# LLM embedding space via the `akasha_compiler` reference runtime.
#
# To load this from Python:
#     from akasha_compiler.solution import load_solution
#     from pathlib import Path
#     sln = load_solution(Path("examples/solution/embedding-pipeline.aksln"))
#     for p in sln.projects_in_build_order:
#         print(p.name, p.substrate, [str(s) for s in p.sources])
#
# To validate from the command line:
#     python -m akasha_compiler.solution examples/solution/embedding-pipeline.aksln
#
# The spec for this file format is at
# planning/akasha-spec/22-solutions.md.

[solution]
name = "embedding-pipeline"
akasha_version = "0.2"
description = "Small example solution: corpus + similarity queries."
default_substrate = "silicon"

[[project]]
path = "corpus"

[[project]]
path = "similarity"
