// Loop demo: eigenrotation through vector space with a snap-to-codebook
// terminal commit.
//
// `loop (condition) { body }` is Sutra's data-dependent loop. The
// compiler replaces the body with a fixed rotation matrix R and
// iterates `state <- R @ state` on the substrate. The loop terminates
// when the state enters the target basin (cosine above threshold) or
// when max_iters is reached. This IS the language's only source of
// unbounded runtime iteration — `loop[N]` unrolls at compile time.
//
// Terminal commit: argmax_cosine against a codebook of candidate
// phrases. Per the spec, snap is one possible terminal commit, not
// the only one; this example demonstrates the pattern.

vector v_cat     = basis_vector("cat");
vector v_dog     = basis_vector("dog");
vector v_bird    = basis_vector("bird");
vector v_fish    = basis_vector("fish");
vector v_rabbit  = basis_vector("rabbit");

map<vector, string> ANIMAL_NAME = {
    v_cat:    "cat",
    v_dog:    "dog",
    v_bird:   "bird",
    v_fish:   "fish",
    v_rabbit: "rabbit"
};

// Rotate `start` through the vector space until the trajectory enters
// a basin, then snap to the nearest codebook entry.
function string wander_then_snap(vector start) {
    vector state = start;
    loop (similarity(state, v_dog) < 0.9) {
        state = state;
    }
    vector winner = argmax_cosine(state,
        [v_cat, v_dog, v_bird, v_fish, v_rabbit]);
    return ANIMAL_NAME[winner];
}

function string main() {
    return wander_then_snap(v_cat);
}
