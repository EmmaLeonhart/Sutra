// Sequence encoding via position-bound bundle.
//
// A sequence of tokens is stored as one flat vector:
//
//   encode(seq) = bundle(bind(pos_0, token_0),
//                        bind(pos_1, token_1),
//                        ...,
//                        bind(pos_N-1, token_N-1))
//
// Decoding the token at position i:
//
//   decode_at(record, pos_i) = argmax_cosine(
//       unbind(pos_i, record),
//       token_codebook)
//
// In bind(role, filler) — Sutra's role-first convention — the role
// (first argument) is the lookup key that seeds the rotation; the
// filler (second argument) carries the real-valued magnitude pattern
// that survives unbinding. Here the position is the role and the token
// is the filler, so unbinding by position recovers the token.
//
// Two sequences share a single token codebook. Each is encoded into
// a 256-dim vector and decoded position by position. This is the
// first Sutra demo that treats a vector as an *ordered sequence*
// rather than a record or a state.

// --- Positions ---
vector pos_0 = embed("pos_0");
vector pos_1 = embed("pos_1");
vector pos_2 = embed("pos_2");
vector pos_3 = embed("pos_3");
vector pos_4 = embed("pos_4");

// --- Token codebook ---
vector the     = embed("tok_the");
vector quick   = embed("tok_quick");
vector brown   = embed("tok_brown");
vector fox     = embed("tok_fox");
vector jumps   = embed("tok_jumps");
vector lazy    = embed("tok_lazy");
vector dog     = embed("tok_dog");
vector over    = embed("tok_over");
vector a       = embed("tok_a");
vector sleeps  = embed("tok_sleeps");

map<vector, string> TOKEN_NAME = {
    the:    "the",
    quick:  "quick",
    brown:  "brown",
    fox:    "fox",
    jumps:  "jumps",
    lazy:   "lazy",
    dog:    "dog",
    over:   "over",
    a:      "a",
    sleeps: "sleeps"
};

// --- Two encoded sequences ---
// "the quick brown fox jumps"
vector seq_fox = bundle(
    bind(pos_0, the),
    bind(pos_1, quick),
    bind(pos_2, brown),
    bind(pos_3, fox),
    bind(pos_4, jumps)
);

// "a lazy brown dog sleeps"
vector seq_dog = bundle(
    bind(pos_0, a),
    bind(pos_1, lazy),
    bind(pos_2, brown),
    bind(pos_3, dog),
    bind(pos_4, sleeps)
);

// Decode the token at a given position.
function string decode_at(vector record, vector position) {
    vector recovered = unbind(position, record);
    vector winner = argmax_cosine(recovered,
        [the, quick, brown, fox, jumps, lazy, dog, over, a, sleeps]);
    return TOKEN_NAME[winner];
}

// How similar are two sequence encodings? (Sequences sharing tokens
// at the same positions will have high cosine; disjoint sequences
// will have low cosine.)
function number seq_similarity(vector a_seq, vector b_seq) {
    return similarity(a_seq, b_seq);
}

function string main() {
    return decode_at(seq_fox, pos_3);
}
