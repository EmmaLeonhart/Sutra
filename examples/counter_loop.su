// Counter-in-loop(cond) — a minimal demonstration of unbounded,
// data-dependent iteration in Sutra. The loop counter is NOT a host
// integer. It is the angular position of the state vector on the
// helix R^i · v_0 in substrate space. Termination is a snap against
// a codebook: when the rotated state enters a basin, the loop exits.
//
// Combined with `select` (arbitrary boolean composition over fuzzy
// state) this is computationally universal under the standard VSA
// arguments (binding/bundling give addressable memory; this file
// gives unbounded iteration; select gives branching). Turing-
// completeness is thus not asserted — it is constructed, op by op,
// from the primitives the compiler actually emits.

vector v_start = basis_vector("start");
vector v_goal  = basis_vector("goal");

vector v_step_1  = basis_vector("step_one");
vector v_step_5  = basis_vector("step_five");
vector v_step_20 = basis_vector("step_twenty");

map<vector, string> STEP_NAME = {
    v_step_1:  "step_one",
    v_step_5:  "step_five",
    v_step_20: "step_twenty"
};

// Rotate from start until we drift near `goal`, then snap the
// terminated state to one of three "step count" prototypes. The
// prototype that snaps is determined by where on the helix the
// trajectory happened to terminate — that is the substrate's
// realization of the iteration count.
function string count_then_snap() {
    vector state = v_start;
    loop (similarity(state, v_goal) < 0.9) {
        state = state;
    }
    vector winner = argmax_cosine(state,
        [v_step_1, v_step_5, v_step_20]);
    return STEP_NAME[winner];
}

function string main() {
    return count_then_snap();
}
