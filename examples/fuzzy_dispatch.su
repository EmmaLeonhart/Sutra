// N-way fuzzy dispatch with *structured* branch results.
//
// fuzzy_branching.su picks one of 4 scalar behaviors. This demo
// generalizes: each branch's result is a role-filler record
// (action, target) rather than a single vector. The dispatch produces
// a weighted superposition of records, and the caller decodes both
// fields from the winning record with separate unbinds.
//
// Four intents:
//   "weather today"   -> action=lookup, target=weather
//   "play jazz"       -> action=start,  target=music
//   "set timer 5min"  -> action=start,  target=timer
//   "cancel alarm"    -> action=stop,   target=alarm
//
// The decoder returns a string describing what was extracted from
// the winning record. No control flow — dispatch is a weighted sum
// across all four branches, argmax is at the final codebook lookup.

// --- Intent prototypes (the "query" side) ---
vector q_weather = embed("q_weather");
vector q_music   = embed("q_music");
vector q_timer   = embed("q_timer");
vector q_cancel  = embed("q_cancel");

// --- Roles ---
vector r_action = embed("r_action");
vector r_target = embed("r_target");

// --- Action codebook ---
vector a_lookup = embed("a_lookup");
vector a_start  = embed("a_start");
vector a_stop   = embed("a_stop");

// --- Target codebook ---
vector t_weather = embed("t_weather");
vector t_music   = embed("t_music");
vector t_timer   = embed("t_timer");
vector t_alarm   = embed("t_alarm");

map<vector, string> ACTION_NAME = {
    a_lookup: "lookup",
    a_start:  "start",
    a_stop:   "stop"
};

map<vector, string> TARGET_NAME = {
    t_weather: "weather",
    t_music:   "music",
    t_timer:   "timer",
    t_alarm:   "alarm"
};

// --- Branch records: (action, target) bundled via role-filler. ---
vector rec_weather = bundle(bind(r_action, a_lookup), bind(r_target, t_weather));
vector rec_music   = bundle(bind(r_action, a_start),  bind(r_target, t_music));
vector rec_timer   = bundle(bind(r_action, a_start),  bind(r_target, t_timer));
vector rec_cancel  = bundle(bind(r_action, a_stop),   bind(r_target, t_alarm));

// Decode a dispatched record into "action:target" string.
function string describe(vector record) {
    vector a = unbind(r_action, record);
    vector t = unbind(r_target, record);
    vector aw = argmax_cosine(a, [a_lookup, a_start, a_stop]);
    vector tw = argmax_cosine(t, [t_weather, t_music, t_timer, t_alarm]);
    return ACTION_NAME[aw] + ":" + TARGET_NAME[tw];
}

// Dispatch: softmax-weighted superposition of all four branch records
// via the `select` primitive (planning/sutra-spec/26-select-and-gate.md).
// All four branches contribute; softmax sharpens the highest-similarity
// score so the matching branch dominates the resulting record, and the
// downstream `describe` decodes the (action, target) pair.
//
// `select(scores, options)` is the spec's named conditional-branching
// primitive. It is differentiable, defuzz-free, and substrate-resident:
// the result is a vector usable directly as input to further ops.
// The scores are sharpened (×10) before the softmax. Raw cosines sit
// in a narrow band (winner ~1.0, runners-up ~0.6-0.7), and at softmax
// temperature 1 that gives the winning record only ~0.32 weight — so
// an action shared by TWO records ("start" in rec_music + rec_timer,
// combined ~0.47) out-votes the true action in the superposition and
// the decode is wrong BY CONSTRUCTION, not by noise. The ×10 gain is
// the explicit temperature (spec: select carries a trainable softmax
// temperature); it lifts the winner to ~0.9 weight and the decode
// separates cleanly.
function string dispatch(vector query) {
    vector result = select(
        [10 * similarity(query, q_weather),
         10 * similarity(query, q_music),
         10 * similarity(query, q_timer),
         10 * similarity(query, q_cancel)],
        [rec_weather, rec_music, rec_timer, rec_cancel]
    );
    return describe(result);
}

function string main() {
    return dispatch(q_weather);
}
