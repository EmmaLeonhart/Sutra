// Real-WebAssembly-bytecode core on the substrate (Phase 5; scoped in
// planning/exploratory/2026-06-17-phase5-wasm-core-scoping.md). SAME RAM-state
// blended-dispatch DNC stack machine as jvm_core.su, but with REAL WASM opcode
// values and the WASM operand encoding (LEB128), so eventual wat->wasm output runs
// unmodified. The host drives one step() per instruction (autoregressive); all
// state lives in the RAM device; dispatch is truth_axis(defuzzy(op == N)); side
// effects are blended writes to fixed cells. Semantics match the W3C WebAssembly
// spec's small-step reduction rules for this subset.
//
// STEPS 1a+1b+2+3 (this file): the i32 arithmetic subset with real opcodes + single-
// byte signed LEB128 for i32.const, INDEXED locals (local.get/set/tee with an unsigned
// single-byte LEB128 index — NEW vs the JVM core's fixed-opcode locals: the local cell
// is computed 200+idx, a hard-addressed write), COMPARISONS (i32.eqz + the six
// ordered/equality i32 compares), and STRUCTURED CONTROL — block/loop/if/else/br/br_if/end
// via a load-time PRE-RESOLVED target table (host-side compilation resolves the nesting to
// absolute targets; the substrate reads the table + does a JVM-shaped jump).
//
// SUBSTRATE-PURE: no .real(), no host arithmetic on values — values stay number-
// vectors; comparisons/dispatch are 0-dim truth-axis tensors; ram addresses decode
// at the device boundary. pc/sp/operand-stack are vectors carried in RAM across
// recurrent step() calls (a genuine RNN/DNC); the only host readout is hard
// address-decode to pick a RAM cell.
//
// RAM layout: [0]=pc  [1]=sp  [2]=fp(current frame base)  [3]=nloc(current frame's
// local count)   function body bytecode at 10+ (one byte/cell)   pre-resolved
// branch-target table at 400+ (cell 400+offset = 390+pc holds the absolute jump-target
// pc).  FRAME ARENA at 600+: the current frame's locals at fp+idx, operand stack at
// obase=fp+nloc (operand k at obase+k). (Single-frame programs: fp=600, nloc set at load.)
// Opcodes (real WASM byte values, hex/decimal):
//   0x41/65=i32.const(push next byte as signed single-byte LEB128; 2-byte instr)
//   0x20/32=local.get  0x21/33=local.set  0x22/34=local.tee  (each + an unsigned
//     single-byte LEB128 local index; 2-byte instr. get pushes local[idx]; set pops
//     top into local[idx]; tee writes local[idx] but LEAVES the value on the stack.)
//   0x6a/106=i32.add  0x6b/107=i32.sub  0x6c/108=i32.mul
//   0x45/69=i32.eqz(unary: top==0)  0x46/70=i32.eq  0x47/71=i32.ne  0x48/72=i32.lt_s
//   0x4a/74=i32.gt_s  0x4c/76=i32.le_s  0x4e/78=i32.ge_s  (binary: push 0/1)
//   0x02/2=block  0x03/3=loop  (+blocktype byte; runtime no-ops, targets in the table)
//   0x04/4=if(+blocktype; pop cond; nonzero->then-arm, zero->else+1/end+1)  0x05/5=else
//     (jump to matching end+1 — reached only at the end of the then-arm)
//   0x0c/12=br(unconditional)  0x0d/13=br_if(pop cond; branch iff nonzero)  (+LEB label)
//   0x0b/11=end(table: inner->fall-through, function-final->halt)  0x0f/15=return(halt)
// Binary ops pop two (top1=top, top2=second) and push combine(top2, top1). pc
// advances 2 for i32.const, 1 for arithmetic; end/return keep pc so the machine
// idles with the result on top.
function int step(scalar d) {
    int pc = ramRead(0);
    int sp = ramRead(1);
    // FRAME-RELATIVE addressing (step 5a, toward call/recursion): the current frame's
    // locals live at fp+idx and its operand stack at obase=fp+nloc (operand k at
    // obase+k, top at obase+sp-1). fp/nloc are RAM state so a future `call` can switch
    // frames. (Single-frame programs set fp=arena base, nloc=local count at load.)
    int fp = ramRead(2);
    int nloc = ramRead(3);
    int csp = ramRead(4);        // control-stack pointer (return-frame stack); 1500 + 4*depth
    int obase = fp + nloc;
    int op = ramRead(pc);
    int imm = ramRead(pc + 1);
    // ---- Multi-byte (2-byte / 14-bit) LEB128 decode ----
    // The operand of a 2-byte op may be a TWO-byte LEB128 when the value/index
    // exceeds 7 bits: byte0 carries its low 7 bits with the 0x80 continuation bit
    // set, byte1 carries bits 7..13. `cont0` = byte0 has the continuation bit.
    // Boundary-clean detection: 2*imm < 255 (255 is odd, 2*imm even -> never equal)
    // is exactly imm <= 127, so cont0 = NOT that = (imm >= 128). 3+ byte operands
    // are out of scope (the host loader asserts none appear) -> branchless, no loop.
    int imm1 = ramRead(pc + 2);                                       // second operand byte (used iff cont0)
    int cont0 = 1 - ((truth_axis(defuzzy((2 * imm) < 255)) + 1) / 2); // 1 iff imm >= 128
    int imm_low = imm - (128 * cont0);                               // byte0 low 7 bits
    // UNSIGNED value (local/call/label index): byte0_low + (byte1 << 7) when cont0;
    // exactly `imm` when single-byte (cont0=0 -> imm_low=imm, extra term zeroed).
    int mb_uval = imm_low + (128 * cont0 * imm1);
    // SIGNED value (i32.const). The LEB sign is bit 6 of the LAST byte: byte0 when
    // single-byte, byte1 when two-byte. (2*b < 127 <=> b <= 63 = bit6 clear.)
    int sign1 = 1 - ((truth_axis(defuzzy((2 * imm) < 127)) + 1) / 2);   // bit6 of byte0
    int sign2 = 1 - ((truth_axis(defuzzy((2 * imm1) < 127)) + 1) / 2);  // bit6 of byte1
    int mb_sign = (cont0 * sign2) + ((1 - cont0) * sign1);
    // Sign-extend: subtract 2^7 (single-byte) or 2^14 (two-byte) when the sign bit is set.
    int leb_val = mb_uval - (((1 - cont0) * 128 + cont0 * 16384) * mb_sign);
    int top1 = ramRead(obase + sp - 1);
    int top2 = ramRead(obase + sp - 2);
    // Real-axis unit vector (make_complex(1,0)). i32.const's opcode-following
    // constant must be materialized as leb_val*one so it lands on the real axis
    // ONLY — a bare scalar added to a zeroed blend term broadcasts across every
    // axis and silently breaks == (finding 2026-06-17-iconst-literal-broadcast).
    complex one = 1 + 0i;
    int is_const = truth_axis(defuzzy(op == 65));    // i32.const 0x41
    int is_get = truth_axis(defuzzy(op == 32));      // local.get 0x20
    int is_set = truth_axis(defuzzy(op == 33));      // local.set 0x21
    int is_tee = truth_axis(defuzzy(op == 34));      // local.tee 0x22
    int is_add = truth_axis(defuzzy(op == 106));     // i32.add  0x6a
    int is_sub = truth_axis(defuzzy(op == 107));     // i32.sub  0x6b
    int is_mul = truth_axis(defuzzy(op == 108));     // i32.mul  0x6c
    int is_eqz = truth_axis(defuzzy(op == 69));      // i32.eqz  0x45 (unary: top==0)
    int is_eq = truth_axis(defuzzy(op == 70));       // i32.eq   0x46
    int is_ne = truth_axis(defuzzy(op == 71));       // i32.ne   0x47
    int is_lt = truth_axis(defuzzy(op == 72));       // i32.lt_s 0x48
    int is_gt = truth_axis(defuzzy(op == 74));       // i32.gt_s 0x4a
    int is_le = truth_axis(defuzzy(op == 76));       // i32.le_s 0x4c
    int is_ge = truth_axis(defuzzy(op == 78));       // i32.ge_s 0x4e
    int is_block = truth_axis(defuzzy(op == 2));     // block    0x02 (+blocktype byte)
    int is_loop = truth_axis(defuzzy(op == 3));      // loop     0x03 (+blocktype byte)
    int is_if = truth_axis(defuzzy(op == 4));        // if       0x04 (+blocktype byte)
    int is_else = truth_axis(defuzzy(op == 5));      // else     0x05
    int is_br = truth_axis(defuzzy(op == 12));       // br       0x0c (+LEB label)
    int is_br_if = truth_axis(defuzzy(op == 13));    // br_if    0x0d (+LEB label)
    int is_end = truth_axis(defuzzy(op == 11));      // end      0x0b
    int is_return = truth_axis(defuzzy(op == 15));   // return   0x0f
    int is_call = truth_axis(defuzzy(op == 16));     // call     0x10 (+LEB func index)
    // For local.get/set/tee the operand byte `imm` is an unsigned single-byte LEB128
    // local index (0..127); the local lives at the computed cell 200+imm. (For
    // i32.const `imm` is instead the signed LEB value, decoded below.) loc_cur is the
    // local's current value — used to PUSH it (local.get) and as the no-op write-back
    // base when the op is not local.set/tee.
    int loc_cur = ramRead(fp + mb_uval);
    // (i32.const's value `leb_val` and the unsigned index `mb_uval` were decoded above
    // by the multi-byte LEB128 block; both collapse to the old single-byte values when
    // the operand fits in 7 bits, so existing 1-byte programs are byte-for-byte unchanged.)
    // Comparisons as 0/1 values (copies of the JVM gated idiom). WASM i32 compares
    // pop value1 (=top2, deeper) and value2 (=top1, top) and push (value1 <cond> value2):
    //   eq: top2==top1  ne: top2!=top1  lt_s: top2<top1  gt_s: top2>top1
    //   ge_s: top2>=top1  le_s: top2<=top1. == is crisp; strict </> defuzz ambiguously
    // at EXACT equality so gate by (1 - v_eq). eqz is the unary (top1 == 0).
    int v_eq = (truth_axis(defuzzy(top2 == top1)) + 1) / 2;
    int v_lt_raw = (truth_axis(defuzzy(top2 < top1)) + 1) / 2;
    int v_gt_raw = (truth_axis(defuzzy(top1 < top2)) + 1) / 2;
    int v_lt = (1 - v_eq) * v_lt_raw;   // top2 < top1
    int v_gt = (1 - v_eq) * v_gt_raw;   // top2 > top1
    int v_ge = 1 - v_lt;                // top2 >= top1
    int v_le = 1 - v_gt;                // top2 <= top1
    int v_eqz = (truth_axis(defuzzy(top1 == 0)) + 1) / 2;
    // 100+sp (new top cell): i32.const pushes leb_val (as a real-axis vector); else
    // keep the cell.
    int cell_hi = ramRead(obase + sp);
    // local.get pushes the local's current value (already a real-axis vector from RAM).
    int hi_get = (((1 + is_get) * (loc_cur)) + ((1 - is_get) * (cell_hi))) / 2;
    int new_hi = (((1 + is_const) * (leb_val * one)) + ((1 - is_const) * (hi_get))) / 2;
    ramWrite(obase + sp, new_hi);
    // Indexed local write (200+imm): local.set/tee write top1 there; any other op
    // writes the cell's existing value back (a no-op — safe even if imm aliases a
    // used local, since writing a cell's current value to itself changes nothing).
    int loc_set = (((1 + is_set) * (top1)) + ((1 - is_set) * (loc_cur))) / 2;
    int new_loc = (((1 + is_tee) * (top1)) + ((1 - is_tee) * (loc_set))) / 2;
    // The local write must NOT bleed into the operand region: locals (fp+idx) and the
    // operand stack (fp+nloc) are now ADJACENT, and `imm` is a garbage operand byte for
    // non-local ops, so `fp+imm` could hit an in-use operand cell and clobber a push made
    // this same step. Gate the WRITE address to a scratch cell (RAM 5) unless the op is
    // actually local.set/local.tee (where `imm` is a small index < nloc, staying in the
    // locals region). The read of `loc_cur` above is harmless (a read can't corrupt).
    int set01 = ((is_set + 1) / 2) + ((is_tee + 1) / 2);
    int loc_addr = (set01 * (fp + mb_uval)) + ((1 - set01) * (5));
    ramWrite(loc_addr, new_loc);
    // 98+sp (binary result): add/sub/mul write here; net sp -1 collapses the top so
    // the result lands at the new top (99+(sp-1) = 98+sp). Else keep top2.
    int v_add = top2 + top1;
    int v_sub = top2 - top1;
    int v_mul = top2 * top1;
    int b_mul = (((1 + is_mul) * (v_mul)) + ((1 - is_mul) * (top2))) / 2;
    int b_sub = (((1 + is_sub) * (v_sub)) + ((1 - is_sub) * (b_mul))) / 2;
    // Binary comparisons push their 0/1 result here too (net sp -1). Each result is
    // materialized as v*one (real-axis vector), NOT a bare scalar — a scalar would
    // broadcast across all axes (the iconst-literal-broadcast finding) and break a
    // later == / br_if on the pushed flag.
    int b_eq = (((1 + is_eq) * (v_eq * one)) + ((1 - is_eq) * (b_sub))) / 2;
    int b_ne = (((1 + is_ne) * ((1 - v_eq) * one)) + ((1 - is_ne) * (b_eq))) / 2;
    int b_lt = (((1 + is_lt) * (v_lt * one)) + ((1 - is_lt) * (b_ne))) / 2;
    int b_gt = (((1 + is_gt) * (v_gt * one)) + ((1 - is_gt) * (b_lt))) / 2;
    int b_le = (((1 + is_le) * (v_le * one)) + ((1 - is_le) * (b_gt))) / 2;
    int b_ge = (((1 + is_ge) * (v_ge * one)) + ((1 - is_ge) * (b_le))) / 2;
    int new_lo = (((1 + is_add) * (v_add)) + ((1 - is_add) * (b_ge))) / 2;
    ramWrite(obase + sp - 2, new_lo);
    // top cell (in place): i32.eqz replaces the top with (top == 0); else keep top1.
    int new_99 = (((1 + is_eqz) * (v_eqz * one)) + ((1 - is_eqz) * (top1))) / 2;
    ramWrite(obase + sp - 1, new_99);
    // pc advancement + branch target (needed by both the branch chain and the
    // function-return detection). 2-byte ops skip their 1 operand byte (call too);
    // a 2-byte LEB128 operand (cont0=1) skips ONE MORE byte. `two_byte` is 0/1 (the
    // opcodes are mutually exclusive), so `two_byte * cont0` adds the continuation
    // byte ONLY for an operand-bearing op whose first operand byte continues — a
    // non-operand op's garbage `imm` cannot inflate the advance.
    int two_byte = ((is_const + 1) / 2) + ((is_get + 1) / 2) + ((is_set + 1) / 2)
                 + ((is_tee + 1) / 2) + ((is_block + 1) / 2) + ((is_loop + 1) / 2)
                 + ((is_if + 1) / 2) + ((is_br + 1) / 2) + ((is_br_if + 1) / 2)
                 + ((is_call + 1) / 2);
    int pc_seq = pc + 1 + two_byte + (two_byte * cont0);
    int pc_tgt = ramRead(390 + pc);   // pre-resolved branch/halt target (load-time table)
    // ---- NORMAL sp chain (the no-call/return case) ----
    int sp_binop = sp - 1;
    int s_mul = (((1 + is_mul) * (sp_binop)) + ((1 - is_mul) * (sp))) / 2;
    int s_sub = (((1 + is_sub) * (sp_binop)) + ((1 - is_sub) * (s_mul))) / 2;
    int s_add = (((1 + is_add) * (sp_binop)) + ((1 - is_add) * (s_sub))) / 2;
    int s_eq = (((1 + is_eq) * (sp_binop)) + ((1 - is_eq) * (s_add))) / 2;
    int s_ne = (((1 + is_ne) * (sp_binop)) + ((1 - is_ne) * (s_eq))) / 2;
    int s_lt = (((1 + is_lt) * (sp_binop)) + ((1 - is_lt) * (s_ne))) / 2;
    int s_gt = (((1 + is_gt) * (sp_binop)) + ((1 - is_gt) * (s_lt))) / 2;
    int s_le = (((1 + is_le) * (sp_binop)) + ((1 - is_le) * (s_gt))) / 2;
    int s_ge = (((1 + is_ge) * (sp_binop)) + ((1 - is_ge) * (s_le))) / 2;
    int s_brif = (((1 + is_br_if) * (sp_binop)) + ((1 - is_br_if) * (s_ge))) / 2;
    int s_if = (((1 + is_if) * (sp_binop)) + ((1 - is_if) * (s_brif))) / 2;
    int s_get = (((1 + is_get) * (sp + 1)) + ((1 - is_get) * (s_if))) / 2;
    int s_set = (((1 + is_set) * (sp_binop)) + ((1 - is_set) * (s_get))) / 2;
    int sp_norm = (((1 + is_const) * (sp + 1)) + ((1 - is_const) * (s_set))) / 2;
    // ---- NORMAL pc chain (branches; return/func-end halt when there is no caller) ----
    int brif_tgt = ((1 - v_eqz) * pc_tgt) + (v_eqz * pc_seq);
    int if_tgt = (v_eqz * pc_tgt) + ((1 - v_eqz) * pc_seq);
    int p_if = (((1 + is_if) * (if_tgt)) + ((1 - is_if) * (pc_seq))) / 2;
    int p_else = (((1 + is_else) * (pc_tgt)) + ((1 - is_else) * (p_if))) / 2;
    int p_brif = (((1 + is_br_if) * (brif_tgt)) + ((1 - is_br_if) * (p_else))) / 2;
    int p_br = (((1 + is_br) * (pc_tgt)) + ((1 - is_br) * (p_brif))) / 2;
    int p_end = (((1 + is_end) * (pc_tgt)) + ((1 - is_end) * (p_br))) / 2;
    int pc_norm = (((1 + is_return) * (pc)) + ((1 - is_return) * (p_end))) / 2;
    // ---- CALL / RETURN frame machinery (step 5b) ----
    // Callee descriptor from the host-built function table (RAM 2000 + idx*3 =
    // [start_pc, nargs, nlocals]). For non-call ops `imm` is a garbage index -> harmless
    // reads (the call branch is not taken).
    int ft = 2000 + (mb_uval * 3);
    int ce_pc = ramRead(ft);
    int ce_na = ramRead(ft + 1);
    int ce_nl = ramRead(ft + 2);
    int fp_call = obase + sp - ce_na;          // args-in-place: callee frame aliases caller's top args
    int do_call01 = (is_call + 1) / 2;
    // control stack: csp = 1500 + 4*depth; empty iff csp==1500 ((2*csp)<3003, even/odd clean).
    int csp_empty = (truth_axis(defuzzy((2 * csp) < 3003)) + 1) / 2;
    int csp_nz = 1 - csp_empty;
    // a function returns on `return`, or on its function-final `end` (table marks it
    // pc_tgt==pc; inner ends have pc_tgt==pc+1). do_ret only when a caller exists.
    int at_func_end = (truth_axis(defuzzy(pc_tgt == pc)) + 1) / 2;
    int ret01 = ((is_return + 1) / 2) + (((is_end + 1) / 2) * at_func_end);
    int do_ret = ret01 * csp_nz;
    // control PUSH (4 cells at csp), gated so non-call steps write back (no-op):
    // [return_pc, saved_fp, saved_nloc, saved_caller_sp(after arg consumption)].
    int e0 = (do_call01 * (pc + 2)) + ((1 - do_call01) * ramRead(csp));
    ramWrite(csp, e0);
    int e1 = (do_call01 * (fp)) + ((1 - do_call01) * ramRead(csp + 1));
    ramWrite(csp + 1, e1);
    int e2 = (do_call01 * (nloc)) + ((1 - do_call01) * ramRead(csp + 2));
    ramWrite(csp + 2, e2);
    int e3 = (do_call01 * (sp - ce_na)) + ((1 - do_call01) * ramRead(csp + 3));
    ramWrite(csp + 3, e3);
    // control POP (top entry at csp-4) for return.
    int ret_pc = ramRead(csp - 4);
    int s_fp = ramRead(csp - 3);
    int s_nloc = ramRead(csp - 2);
    int s_sp = ramRead(csp - 1);
    // return value (callee operand top) is pushed where the args were in the caller
    // (s_fp+s_nloc+s_sp); gated by do_ret -> else a scratch cell (6).
    int rv = ramRead(obase + sp - 1);
    int rv_addr = (do_ret * (s_fp + s_nloc + s_sp)) + ((1 - do_ret) * (6));
    ramWrite(rv_addr, rv);
    // ---- final 3-way state select: call vs return vs normal (mutually exclusive) ----
    int norm = 1 - do_call01 - do_ret;
    int new_sp = (do_call01 * (0)) + (do_ret * (s_sp + 1)) + (norm * sp_norm);
    ramWrite(1, new_sp);
    int new_pc = (do_call01 * ce_pc) + (do_ret * ret_pc) + (norm * pc_norm);
    ramWrite(0, new_pc);
    int new_fp = (do_call01 * fp_call) + (do_ret * s_fp) + (norm * fp);
    ramWrite(2, new_fp);
    int new_nloc = (do_call01 * ce_nl) + (do_ret * s_nloc) + (norm * nloc);
    ramWrite(3, new_nloc);
    int new_csp = (do_call01 * (csp + 4)) + (do_ret * (csp - 4)) + (norm * csp);
    ramWrite(4, new_csp);
    return ramRead(obase + sp - 1);
}
function string main() { return "ok"; }
