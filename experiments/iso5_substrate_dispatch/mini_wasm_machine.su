// Mini RAM-state WASM stack machine (2026-06-06; SUBSTRATE-PURE rewrite
// 2026-06-07). All machine state lives in RAM (Emma: "the wasm array is ram");
// the host drives steps (autoregressive model — one step per call), so no
// multi-slot recur is needed (spec: v1 recur has one slot).
//
// SUBSTRATE-PURE (2026-06-07): ZERO `.real()` — values stay number-VECTORS end
// to end. Arithmetic is element-wise vector +/-/* (substrate); comparisons use
// the numeric operators ==/</> (route to eq_synthetic/gt on the truth axis —
// a boolean is a fuzzy scalar on the truth axis, +1/-1, per
// equality-and-defuzzification.md:92); dispatch is truth_axis(defuzzy(op==N))
// (a 0-dim tensor, no host readout); addresses (pc/sp) are vectors that ramRead/
// ramWrite decode at the device boundary (the I/O wire). No host-float arithmetic,
// no introspection. Verified: test_mini_wasm_machine.py 30/30 on the substrate.
// (Earlier versions used ramRead(...).real() and did ADD/SUB/MUL on host floats —
// a substrate breach now removed.)
// Opcode dispatch reads the opcode FRESH from RAM each step
// (ramRead(pc) == tag), which dispatches cleanly against literals.
// Side effects are single blended writes to FIXED addresses (no address
// blending): each cell is written its new value if its opcode matched, else
// rewritten with its existing value (a no-op).
//
// RAM layout: [0]=pc  [1]=sp  [2]=halted   program at 10+  stack at 100+
// Opcodes: 0=HALT  1=CONST(imm at pc+1)  2=ADD  3=SUB  4=MUL  5=AND(bitwise)
//          6=BR_IF(imm = absolute target; pop top, jump if nonzero else fall through)
//          7=LOAD(pop addr, push ram[addr])  8=STORE(pop value, pop addr, ram[addr]=value)
//          9=EQ(push top2==top1 ?1:0)  10=LT(push top2<top1 ?1:0)
//          11=OUTPUT(pop value, append byte to the output buffer)
//          12=OR(bitwise)  13=XOR(bitwise)  14=DUP(push copy of top)
//          15=SWAP(swap top two)  16=DROP(pop, discard)
//          17=GT(top2>top1 ?1:0)  18=GE(top2>=top1)  19=LE(top2<=top1)  20=NE(top2!=top1)
//          21=NEG(pop a, push -a; unary, net sp 0 — rewrites the top cell)
//          22=MIN(pop top1,top2; push min(top2,top1); binary, net sp -1)
//          23=MAX(pop top1,top2; push max(top2,top1); binary, net sp -1)
//          24=OVER(push a copy of the second-from-top; net sp +1, like DUP of top2)
//          25=ABS(pop a, push |a|; unary, net sp 0; boundary-correct at 0)
//          26=SQR(pop a, push a*a; unary, net sp 0)
//          27=NIP(drop the second-from-top, keep top; net sp -1)
//          28=ROT([a b c] -> [b c a]; rotate top three, net sp 0)
// State: [0]=pc [1]=sp [2]=halted [3]=out_ptr. Program at 10+, stack at 100+,
// output buffer at 300+ (out_ptr counts bytes emitted). Data memory: any region the
// program uses for LOAD/STORE (e.g. 200+), clear of the above. LOAD/STORE + BR_IF
// enable memory-counter loops (backward branch) -> Turing-complete.
// Binary ops pop two (top1=top, top2=second), push combine(top2, top1)
// (matching the reference's `let b=pop in let a=pop in push (a OP b)`).
function int step(scalar d) {
    int pc = ramRead(0);
    int sp = ramRead(1);
    int op = ramRead(pc);
    int imm = ramRead(pc + 1);
    int top1 = ramRead(99 + sp);
    int top2 = ramRead(98 + sp);
    int top3 = ramRead(97 + sp);   // third-from-top (for ROT); unused by other ops
    int is_const = truth_axis(defuzzy(op == 1));
    int is_add = truth_axis(defuzzy(op == 2));
    int is_sub = truth_axis(defuzzy(op == 3));
    int is_mul = truth_axis(defuzzy(op == 4));
    int is_and = truth_axis(defuzzy(op == 5));
    int is_brif = truth_axis(defuzzy(op == 6));
    int is_load = truth_axis(defuzzy(op == 7));
    int is_store = truth_axis(defuzzy(op == 8));
    int is_eq = truth_axis(defuzzy(op == 9));
    int is_lt = truth_axis(defuzzy(op == 10));
    int is_output = truth_axis(defuzzy(op == 11));
    int is_or = truth_axis(defuzzy(op == 12));
    int is_xor = truth_axis(defuzzy(op == 13));
    int is_dup = truth_axis(defuzzy(op == 14));
    int is_swap = truth_axis(defuzzy(op == 15));
    int is_drop = truth_axis(defuzzy(op == 16));
    int is_gt = truth_axis(defuzzy(op == 17));
    int is_ge = truth_axis(defuzzy(op == 18));
    int is_le = truth_axis(defuzzy(op == 19));
    int is_ne = truth_axis(defuzzy(op == 20));
    int is_neg = truth_axis(defuzzy(op == 21));
    int is_min = truth_axis(defuzzy(op == 22));
    int is_max = truth_axis(defuzzy(op == 23));
    int is_over = truth_axis(defuzzy(op == 24));
    int is_abs = truth_axis(defuzzy(op == 25));
    int is_sqr = truth_axis(defuzzy(op == 26));
    int is_nip = truth_axis(defuzzy(op == 27));
    int is_rot = truth_axis(defuzzy(op == 28));
    int is_halt = truth_axis(defuzzy(op == 0));
    // BR_IF: pop the top as a condition; if nonzero jump to imm (absolute
    // address), else fall through. taken = is_brif AND (cond != 0), as a clean
    // ±1 truth (the AND-probability of two ±1 flags mapped back to ±1).
    int cond_nz = truth_axis(defuzzy(top1 != 0));
    int taken = (((1 + is_brif) * (1 + cond_nz)) / 2) - 1;
    // CONST writes the new top cell (100+sp) = imm; DUP writes it = top1 (push a
    // copy of the current top); else keeps it.
    int cell_hi = ramRead(100 + sp);
    int hi_dup = (((1 + is_dup) * (top1)) + ((1 - is_dup) * (cell_hi))) / 2;
    // OVER pushes a copy of the SECOND-from-top (top2) onto a new top cell
    // (100+sp); like DUP but copies top2 instead of top1. Net sp +1.
    int hi_over = (((1 + is_over) * (top2)) + ((1 - is_over) * (hi_dup))) / 2;
    int new_hi = (((1 + is_const) * (imm)) + ((1 - is_const) * (hi_over))) / 2;
    ramWrite(100 + sp, new_hi);
    // Binary op writes the result cell (98+sp = second-from-top), else keeps.
    int v_add = top2 + top1;
    int v_sub = top2 - top1;
    int v_mul = top2 * top1;
    // Bitwise needs number-VECTORS (its bit-plane decomposition), so feed the
    // raw ramRead vectors (not the  scalars) and project the result.
    int v_and = Bits.band(ramRead(98 + sp), ramRead(99 + sp));
    int v_or = Bits.bor(ramRead(98 + sp), ramRead(99 + sp));
    int v_xor = Bits.bxor(ramRead(98 + sp), ramRead(99 + sp));
    // EQ / LT / GT / GE / LE / NE push 1 or 0 (truth ±1 mapped to 1/0): top2 OP top1.
    // MEASURED substrate fact (finding 2026-06-06): strict `<` / `>` return ~0.5
    // (the boundary) at EXACT equality, while `==` is clean {0,1} there. So the
    // strict inequalities are gated by (1 - v_eq): at equality v_eq=1 zeroes the
    // ambiguous raw comparison, and `==` decides the boundary. Without this,
    // v_ge = 1 - v_lt collapsed to ~0.5 -> round 0 (7>=7 and 5<=5 both failed).
    int v_eq = (truth_axis(defuzzy(top2 == top1)) + 1) / 2;
    int v_lt_raw = (truth_axis(defuzzy(top2 < top1)) + 1) / 2;
    int v_gt_raw = (truth_axis(defuzzy(top1 < top2)) + 1) / 2;
    int v_lt = (1 - v_eq) * v_lt_raw;
    int v_gt = (1 - v_eq) * v_gt_raw;
    // GE/LE/NE are the boundary-correct negations of LT/GT/EQ.
    int v_ge = 1 - v_lt;
    int v_le = 1 - v_gt;
    int v_ne = 1 - v_eq;
    // MIN(top2, top1): the smaller, selected by the 0/1 v_lt flag (1 iff top2<top1
    // strictly; 0 at equality or top2>top1 — so at equality v_min = top1 = top2).
    // MAX(top2, top1): the larger, by the symmetric v_gt flag (1 iff top2>top1).
    // Both are binary ops (net sp -1): result lands at 98+sp, sp decrements.
    int v_min = (v_lt * top2) + ((1 - v_lt) * top1);
    int v_max = (v_gt * top2) + ((1 - v_gt) * top1);
    // 98+sp (second-from-top) chain. Base keeps top2; SWAP writes top1 here (old
    // top moves down); binary ops (incl. OR/XOR) write their result; net sp -1
    // collapses 99+sp/98+sp so the result/new-top lands at 99+(sp-1)=98+sp.
    int b_swap = (((1 + is_swap) * (top1)) + ((1 - is_swap) * (top2))) / 2;
    // NIP: drop the second-from-top, keep top. The kept value (top1) lands at the
    // new top (98+sp after sp -1); a binary-shaped net sp -1 that writes top1 here.
    int b_nip = (((1 + is_nip) * (top1)) + ((1 - is_nip) * (b_swap))) / 2;
    int b_lt = (((1 + is_lt) * (v_lt)) + ((1 - is_lt) * (b_nip))) / 2;
    int b_gt = (((1 + is_gt) * (v_gt)) + ((1 - is_gt) * (b_lt))) / 2;
    int b_ge = (((1 + is_ge) * (v_ge)) + ((1 - is_ge) * (b_gt))) / 2;
    int b_le = (((1 + is_le) * (v_le)) + ((1 - is_le) * (b_ge))) / 2;
    int b_ne = (((1 + is_ne) * (v_ne)) + ((1 - is_ne) * (b_le))) / 2;
    int b_eq = (((1 + is_eq) * (v_eq)) + ((1 - is_eq) * (b_ne))) / 2;
    int b_xor = (((1 + is_xor) * (v_xor)) + ((1 - is_xor) * (b_eq))) / 2;
    int b_or = (((1 + is_or) * (v_or)) + ((1 - is_or) * (b_xor))) / 2;
    int b_and = (((1 + is_and) * (v_and)) + ((1 - is_and) * (b_or))) / 2;
    int b_mul = (((1 + is_mul) * (v_mul)) + ((1 - is_mul) * (b_and))) / 2;
    int b_sub = (((1 + is_sub) * (v_sub)) + ((1 - is_sub) * (b_mul))) / 2;
    int b_min = (((1 + is_min) * (v_min)) + ((1 - is_min) * (b_sub))) / 2;
    int b_max = (((1 + is_max) * (v_max)) + ((1 - is_max) * (b_min))) / 2;
    // ROT [a b c] -> [b c a] (net sp 0): the middle cell (98+sp) gets the old top
    // (top1=c); the deepest (97+sp) gets the old second (top2=b); the top (99+sp)
    // gets the old third (top3=a). ROT writes 98+sp = top1 here.
    int b_rot = (((1 + is_rot) * (top1)) + ((1 - is_rot) * (b_max))) / 2;
    int new_lo = (((1 + is_add) * (v_add)) + ((1 - is_add) * (b_rot))) / 2;
    ramWrite(98 + sp, new_lo);
    // ROT deepest cell (97+sp) = top2; every other opcode rewrites it with its
    // existing value top3 (a no-op — only ROT touches 97+sp).
    int new_97 = (((1 + is_rot) * (top2)) + ((1 - is_rot) * (top3))) / 2;
    ramWrite(97 + sp, new_97);
    // LOAD: pop addr (top1), push ram[addr] -> rewrite the top cell (99+sp) with
    // the loaded value (else keep). Net sp 0. Data region is the program's choice
    // (use addresses outside [0..2]/program/stack, e.g. 200+).
    int loaded = ramRead(top1);
    // NEG: unary negate the top in place (net sp 0, like LOAD; rewrites 99+sp).
    int v_neg = 0 - top1;
    // ABS: |top1|, unary (net sp 0, like NEG). Boundary-correct negative flag —
    // `top1 < 0` is the strict comparison that defuzzes ambiguously AT 0, so gate
    // it with (1 - is-zero): at top1 == 0, abs_neg = 0 -> v_abs = top1 = 0.
    int abs_is_zero = (truth_axis(defuzzy(top1 == 0)) + 1) / 2;
    int abs_neg = (1 - abs_is_zero) * ((truth_axis(defuzzy(top1 < 0)) + 1) / 2);
    int v_abs = (abs_neg * (0 - top1)) + ((1 - abs_neg) * top1);
    // 99+sp (top) chain: NEG writes -top1; LOAD writes the loaded value; SWAP
    // writes top2 (old second moves up); else keep top1.
    int n99_swap = (((1 + is_swap) * (top2)) + ((1 - is_swap) * (top1))) / 2;
    int n99_load = (((1 + is_load) * (loaded)) + ((1 - is_load) * (n99_swap))) / 2;
    int n99_neg = (((1 + is_neg) * (v_neg)) + ((1 - is_neg) * (n99_load))) / 2;
    int n99_abs = (((1 + is_abs) * (v_abs)) + ((1 - is_abs) * (n99_neg))) / 2;
    // SQR: top1 * top1, unary (net sp 0). Negatives verified, so (-5)^2 = 25.
    int v_sqr = top1 * top1;
    int n99_sqr = (((1 + is_sqr) * (v_sqr)) + ((1 - is_sqr) * (n99_abs))) / 2;
    // ROT moves the old third-from-top (top3=a) to the new top.
    int new_99 = (((1 + is_rot) * (top3)) + ((1 - is_rot) * (n99_sqr))) / 2;
    ramWrite(99 + sp, new_99);
    // STORE: pop value (top1) and addr (top2), write ram[addr]=value (else no-op
    // rewrite of ram[top2] with its existing value). Net sp -2.
    int store_existing = ramRead(top2);
    int store_val = (((1 + is_store) * (top1)) + ((1 - is_store) * (store_existing))) / 2;
    ramWrite(top2, store_val);
    // OUTPUT: pop value (top1), append it to the output buffer at 300+out_ptr and
    // advance out_ptr (ram[3]); else no-op. Net sp -1.
    int out_ptr = ramRead(3);
    int out_existing = ramRead(300 + out_ptr);
    int out_val = (((1 + is_output) * (top1)) + ((1 - is_output) * (out_existing))) / 2;
    ramWrite(300 + out_ptr, out_val);
    int new_out_ptr = (((1 + is_output) * (out_ptr + 1)) + ((1 - is_output) * (out_ptr))) / 2;
    ramWrite(3, new_out_ptr);
    // sp: CONST/DUP +1; binary op (incl OR/XOR) / BR_IF / OUTPUT / DROP -1;
    // STORE -2; LOAD 0 (net); SWAP/HALT/other keep.
    int sp_binop = sp - 1;
    int s_dup = (((1 + is_dup) * (sp + 1)) + ((1 - is_dup) * (sp))) / 2;
    int s_over = (((1 + is_over) * (sp + 1)) + ((1 - is_over) * (s_dup))) / 2;
    int s_const = (((1 + is_const) * (sp + 1)) + ((1 - is_const) * (s_over))) / 2;
    int s_store = (((1 + is_store) * (sp - 2)) + ((1 - is_store) * (s_const))) / 2;
    int s_drop = (((1 + is_drop) * (sp_binop)) + ((1 - is_drop) * (s_store))) / 2;
    int s_nip = (((1 + is_nip) * (sp_binop)) + ((1 - is_nip) * (s_drop))) / 2;
    int s_out = (((1 + is_output) * (sp_binop)) + ((1 - is_output) * (s_nip))) / 2;
    int s_xor = (((1 + is_xor) * (sp_binop)) + ((1 - is_xor) * (s_out))) / 2;
    int s_or = (((1 + is_or) * (sp_binop)) + ((1 - is_or) * (s_xor))) / 2;
    int s_lt = (((1 + is_lt) * (sp_binop)) + ((1 - is_lt) * (s_or))) / 2;
    int s_gt = (((1 + is_gt) * (sp_binop)) + ((1 - is_gt) * (s_lt))) / 2;
    int s_ge = (((1 + is_ge) * (sp_binop)) + ((1 - is_ge) * (s_gt))) / 2;
    int s_le = (((1 + is_le) * (sp_binop)) + ((1 - is_le) * (s_ge))) / 2;
    int s_ne = (((1 + is_ne) * (sp_binop)) + ((1 - is_ne) * (s_le))) / 2;
    int s_eq = (((1 + is_eq) * (sp_binop)) + ((1 - is_eq) * (s_ne))) / 2;
    int s_brif = (((1 + is_brif) * (sp_binop)) + ((1 - is_brif) * (s_eq))) / 2;
    int s_and = (((1 + is_and) * (sp_binop)) + ((1 - is_and) * (s_brif))) / 2;
    int s_mul = (((1 + is_mul) * (sp_binop)) + ((1 - is_mul) * (s_and))) / 2;
    int s_sub = (((1 + is_sub) * (sp_binop)) + ((1 - is_sub) * (s_mul))) / 2;
    int s_min = (((1 + is_min) * (sp_binop)) + ((1 - is_min) * (s_sub))) / 2;
    int s_max = (((1 + is_max) * (sp_binop)) + ((1 - is_max) * (s_min))) / 2;
    int new_sp = (((1 + is_add) * (sp_binop)) + ((1 - is_add) * (s_max))) / 2;
    ramWrite(1, new_sp);
    // pc: HALT keeps; BR_IF-taken jumps to imm; else +2.
    int pc_brif = (((1 + taken) * (imm)) + ((1 - taken) * (pc + 2))) / 2;
    int new_pc = (((1 + is_halt) * (pc)) + ((1 - is_halt) * (pc_brif))) / 2;
    ramWrite(0, new_pc);
    return ramRead(99 + sp);
}
function string main() { return "ok"; }
