# Public FOL discovery — merged via subtree, no longer ignored
# public-fol-discovery/

# Model weights (large binary files — never commit)
*.gguf

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# Local fly-brain working data — the fly-brain backend was retired
# 2026-04-26 but the user keeps a local working mirror of FlyWire
# data at fly-brain/flywire_data/ for possible future revival. The
# authoritative copy lives at C:\Users\Immanuelle\flybrain\.
fly-brain/

# Generated 3D visualizations (--run-viz output)
*_viz.html
*_trace.json

# Compiler emit output — regenerable from .su via `sutrac --emit`.
*_emitted.py

# torch.compile / Inductor / Triton / NVRTC artifacts. The pipeline
# .su -> PyTorch -> CUDA writes these here; they're a function of the
# host GPU + driver version + torch build, not source.
cuda_artifacts/
torchinductor_cache/

# MkDocs build output
_site/

# Paper PDFs staged into docs/ at build time by .github/workflows/pages.yml
# so that mkdocs strict-mode link validation sees them. Not source — the
# workflow rebuilds them each run from paper/paper.tex.
docs/paper.pdf
docs/paper-anonymized.pdf

# Reference PDFs (arxiv, etc.) downloaded by scripts/fetch_reference_pdfs.py.
# We do not commit redistributed papers — we re-download from the
# original source each session. See CLAUDE.md § "Reference PDFs are
# re-downloaded each session, not committed."
references/

# Cached LLM embeddings from experiment runs (e.g. rotation_binding_
# capacity_llm.py). Re-fetched on cache miss; not source.
experiments/_embedding_cache/

# Claude.ai chat exports — only the extracted .md is tracked,
# not the raw HTML / _files/ sources (run scripts/extract_chat.py
# to regenerate the markdown if needed).
chats/*.html
chats/*_files/
experiments/scallop_compare/_build.log
paper/paper.tex.body

# Local PDF inspection caches (paper-pdf.yml artifacts downloaded
# via `gh run download` for page-count / typography review).
.pdf-check/
.pdf-prev/

# NeurIPS style file extraction cache
.neurips-style/

# Supplementary / replication zips (build artifacts regenerated by
# scripts/build_supplementary_zip.py — never committed). Both the
# frozen NeurIPS submission record and the live replication package.
sutra-neurips-supplementary.zip
docs/sutra-neurips-supplementary.zip
sutra-replication-package.zip
docs/sutra-replication-package.zip
# SKILL.md reproduction-capture scratch files (created when the
# replication skill is run from a repo checkout).
diff36.out
diff37.out

# Local copies of the deployed paper PDFs fetched via curl for
# diff-against-artifact verification.
sutralang-paper.pdf
sutralang-paper-anon.pdf

# Local-only handoff and secret-blob files (never commit).
LOKA_README.md
key.b64

# Pre-arXiv feedback folder: keep the distilled docs (discord.md,
# SYNTHESIS.md) tracked; never commit the saved-web-page blobs
# (~8 MB of JS/CSS) — same rationale as not committing reference PDFs.
paper/feedback before arXiv/*.html
paper/feedback before arXiv/*_files/

# Scratch dir for cross-repo comparisons (e.g. cloned paper #1 for
# self-overlap checks). Never commit — clones are re-fetched on demand.
comparisons/
paper/feedback before arXiv/paper.pdf

# Stage A/B generated rule programs (regenerated by the harnesses)
experiments/.stageA_rule.su
experiments/.stageB_param.su
experiments/.stageB_baked.su
experiments/.eqcos_param.su
experiments/.eqcos_baked.su
experiments/.rankk_*.su
experiments/.diff_train_embeddings.pt
experiments/differentiable_training_weights.pt

# Experiment run logs (regenerated by the harnesses)
experiments/*.log

# Local Claude Code launcher script + machine-local settings (never commit).
# The leading ! is escaped so it matches the literal filename, not a re-include.
\!runClaude.bat
.claude/settings.local.json

# Compile artifacts from experiments/ harnesses
experiments/.defuzzgain_*.su
experiments/.*.su
